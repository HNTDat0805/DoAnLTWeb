"use strict";

let connection;
let roomId = "";
let myRole = "";

// don't redeclare `currentPlayer` here with `let` because `ChessLogic.js` defines it;
// expose on window instead
window.currentPlayer = window.currentPlayer || null;

function initRealtime(hubUrl) {

    if (!window.signalR) {
        console.error("SignalR script was not loaded.");
        return;
    }
    connection = new signalR.HubConnectionBuilder()
        .withUrl(hubUrl)
        .build();

    connection.on("ReceiveMove", (...moveData) => {
        if (window.handleReceiveMove)
            window.handleReceiveMove(...moveData);
    });

    connection.on("ReceivePromotion", (pieceType) => {
        if (window.handleReceivePromotion)
            window.handleReceivePromotion(pieceType);
    });

    //  Đăng ký event ở đây
    connection.on("SetRole", (role) => {
        myRole = role;
        document.getElementById("status").innerText = "You are: " + role;
    });

    connection.on("RoomNotFound", () => {
        alert('Room not found. Create the room first.');
    });

    connection.on("RoomFull", () => {
        alert('Room is full.');
    });

    connection.on("StartGame", (startingPlayer) => {
        // startingPlayer is 'white'
        window.currentPlayer = startingPlayer;
        document.getElementById("roleText").innerText = "Current: " + window.currentPlayer;
    });

    connection.start()
        .then(() => console.log("SignalR Connected"))
        .catch(err => console.error(err));
}

function createRoom() {
    roomId = document.getElementById("roomInput").value.trim();
    if (!roomId) return alert("Enter room code");
    if (!connection) return alert('Not connected to server yet. Please wait a moment and try again.');
    if (!connection.invoke) return alert('Connection not ready.');
    connection.invoke("CreateRoom", roomId);
}

function joinRoom() {
    roomId = document.getElementById("roomInput").value.trim();
    if (!roomId) return alert("Enter room code");
    if (!connection) return alert('Not connected to server yet. Please wait a moment and try again.');
    if (!connection.invoke) return alert('Connection not ready.');
    connection.invoke("JoinRoom", roomId);
}

function sendMove(...moveData) {
    if (!connection) return console.error('Not connected to server.');
    connection.invoke("SendMove", roomId, ...moveData)
        .catch(err => console.error("SendMove error:", err));
}

window.getConnection = () => connection;
