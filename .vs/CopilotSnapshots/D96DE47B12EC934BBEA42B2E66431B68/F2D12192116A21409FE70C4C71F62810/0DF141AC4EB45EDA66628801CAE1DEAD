const SIZE = 8;

let board = [];
// Use window.currentPlayer so server can set starting player via realtime
window.currentPlayer = window.currentPlayer || "white";
let gameOver = false;
let moveHistory = [];
let positionHistory = {};
let enPassantTarget = null;
let pendingPromotion = null;

function initBoard() {
    board = Array.from({ length: SIZE }, () => Array(SIZE).fill(null));

    for (let i = 0; i < SIZE; i++) {
        board[6][i] = { type: "pawn", color: "white" };
        board[1][i] = { type: "pawn", color: "black" };
    }

    board[7][0] = board[7][7] = { type: "rook", color: "white" };
    board[0][0] = board[0][7] = { type: "rook", color: "black" };

    board[7][1] = board[7][6] = { type: "knight", color: "white" };
    board[0][1] = board[0][6] = { type: "knight", color: "black" };

    board[7][2] = board[7][5] = { type: "bishop", color: "white" };
    board[0][2] = board[0][5] = { type: "bishop", color: "black" };

    board[7][3] = { type: "queen", color: "white" };
    board[0][3] = { type: "queen", color: "black" };

    board[7][4] = { type: "king", color: "white" };
    board[0][4] = { type: "king", color: "black" };
}

function makeMove(fr, fc, tr, tc, player, skipValidation = false) {

    if (gameOver) return false;

    let piece = board[fr][fc];
    if (!piece) return false;

    if (!skipValidation) {
        if (piece.color !== player) return false;
        if (!isValidMove(fr, fc, tr, tc, piece)) return false;
    }

    let backupTo = board[tr][tc];

    // --- En Passant capture ---
    if (piece.type === "pawn" &&
        enPassantTarget &&
        tr === enPassantTarget.r &&
        tc === enPassantTarget.c) {

        // captured pawn is on the from-row, target-column
        board[fr][tc] = null;
    }

    // --- Castling ---
    if (piece.type === "king" && Math.abs(tc - fc) === 2) {
        let rookFrom = tc > fc ? 7 : 0;
        let rookTo = tc > fc ? 5 : 3;

        board[fr][rookTo] = board[fr][rookFrom];
        board[fr][rookFrom] = null;
        if (board[fr][rookTo]) board[fr][rookTo].moved = true;
    }

    board[tr][tc] = piece;
    board[fr][fc] = null;

    if (!skipValidation) {
        if (isCheck(player)) {
            board[fr][fc] = piece;
            board[tr][tc] = backupTo;
            return false;
        }
    }

    piece.moved = true;

    // --- En Passant set ---
    if (piece.type === "pawn" && Math.abs(tr - fr) === 2) {
        enPassantTarget = { r: (fr + tr) / 2, c: fc };
    } else {
        enPassantTarget = null;
    }

    // --- Promotion ---
    if (piece.type === "pawn" &&
        ((piece.color === "white" && tr === 0) ||
            (piece.color === "black" && tr === 7))) {

        pendingPromotion = { r: tr, c: tc, color: piece.color };
        return "promotion";
    }

    savePosition();

    if (isCheckmate(opponent(player))) {
        alert(player + " wins by checkmate!");
        gameOver = true;
    }

    if (isStalemate(opponent(player))) {
        alert("Draw by stalemate!");
        gameOver = true;
    }

    if (positionHistory[getBoardKey()] >= 3) {
        alert("Draw by repetition!");
        gameOver = true;
    }

    window.currentPlayer = opponent(player);
    return true;
}
function isValidMove(fr, fc, tr, tc, piece) {

    if (tr < 0 || tr >= SIZE || tc < 0 || tc >= SIZE)
        return false;

    let target = board[tr][tc];
    if (target && target.color === piece.color)
        return false;

    let dr = tr - fr;
    let dc = tc - fc;

    switch (piece.type) {

        case "pawn": {
            let dir = piece.color === "white" ? -1 : 1;

            if (dc === 0 && !target) {
                if (dr === dir) return true;

                if (!piece.moved && dr === 2 * dir &&
                    !board[fr + dir][fc])
                    return true;
            }

            if (Math.abs(dc) === 1 && dr === dir) {

                if (target) return true;

                if (enPassantTarget &&
                    tr === enPassantTarget.r &&
                    tc === enPassantTarget.c)
                    return true;
            }

            return false;
        }

        case "rook":
            if (dr === 0 || dc === 0)
                return pathClear(fr, fc, tr, tc);
            return false;

        case "bishop":
            if (Math.abs(dr) === Math.abs(dc))
                return pathClear(fr, fc, tr, tc);
            return false;

        case "queen":
            if (dr === 0 || dc === 0 ||
                Math.abs(dr) === Math.abs(dc))
                return pathClear(fr, fc, tr, tc);
            return false;

        case "knight":
            return (Math.abs(dr) === 2 && Math.abs(dc) === 1) ||
                (Math.abs(dr) === 1 && Math.abs(dc) === 2);

        case "king": {

            if (Math.abs(dr) <= 1 && Math.abs(dc) <= 1)
                return true;

            // CASTLING
            if (dr === 0 && Math.abs(dc) === 2) {

                if (piece.moved) return false;

                let rookCol = dc > 0 ? 7 : 0;
                let rook = board[fr][rookCol];

                if (!rook || rook.type !== "rook" || rook.moved)
                    return false;

                if (!pathClear(fr, fc, fr, rookCol))
                    return false;

                // Cannot be in check currently
                if (isCheck(piece.color))
                    return false;

                // Cannot pass through check
                let step = dc > 0 ? 1 : -1;

                for (let i = 1; i <= 2; i++) {
                    let testC = fc + step * i;

                    // Backup state for safety during test
                    let backupFrom = board[fr][fc];
                    let backupTo = board[fr][testC];
                    let backupEnPassant = enPassantTarget;
                    let backupMoved = piece.moved;

                    board[fr][testC] = piece;
                    board[fr][fc] = null;

                    let check = isCheck(piece.color);

                    board[fr][fc] = backupFrom;
                    board[fr][testC] = backupTo;
                    enPassantTarget = backupEnPassant;
                    piece.moved = backupMoved;

                    if (check) return false;
                }

                return true;
            }

            return false;
        }
    }

    return false;
}
function pathClear(fr, fc, tr, tc) {

    let stepR = Math.sign(tr - fr);
    let stepC = Math.sign(tc - fc);

    let r = fr + stepR;
    let c = fc + stepC;

    while (r !== tr || c !== tc) {
        if (board[r][c]) return false;
        r += stepR;
        c += stepC;
    }

    return true;
}

function isCheck(color) {

    let kingPos = findKing(color);
    if (!kingPos) return false;

    let enemy = opponent(color);

    for (let r = 0; r < SIZE; r++) {
        for (let c = 0; c < SIZE; c++) {
            let p = board[r][c];
            if (p && p.color === enemy) {
                if (isValidMove(r, c, kingPos.r, kingPos.c, p))
                    return true;
            }
        }
    }

    return false;
}

// Simulate an exact move (including en-passant and castling) and return a backup object to restore
function simulateMove(fr, fc, tr, tc) {
    const piece = board[fr][fc];
    const backup = {
        from: { r: fr, c: fc, piece: board[fr][fc] ? { ...board[fr][fc] } : null },
        to: { r: tr, c: tc, piece: board[tr][tc] ? { ...board[tr][tc] } : null },
        enPassant: enPassantTarget ? { ...enPassantTarget } : null,
        castle: null,
        capturedEnPassant: null
    };

    // Handle en-passant capture
    if (piece && piece.type === 'pawn' && enPassantTarget && tr === enPassantTarget.r && tc === enPassantTarget.c) {
        backup.capturedEnPassant = { r: fr, c: tc, piece: board[fr][tc] ? { ...board[fr][tc] } : null };
        board[fr][tc] = null;
    }

    // Handle castling
    if (piece && piece.type === 'king' && Math.abs(tc - fc) === 2) {
        const rookFrom = tc > fc ? 7 : 0;
        const rookTo = tc > fc ? 5 : 3;
        backup.castle = {
            rookFrom,
            rookTo,
            rookPiece: board[fr][rookFrom] ? { ...board[fr][rookFrom] } : null
        };
        board[fr][rookTo] = board[fr][rookFrom];
        board[fr][rookFrom] = null;
    }

    // Move
    board[tr][tc] = piece;
    board[fr][fc] = null;

    // Backup and set moved flag
    if (piece) {
        backup.pieceMoved = piece.moved;
        piece.moved = true;
    }

    // Set enPassantTarget for double pawn move
    if (piece && piece.type === 'pawn' && Math.abs(tr - fr) === 2) {
        enPassantTarget = { r: (fr + tr) / 2, c: fc };
    } else {
        enPassantTarget = null;
    }

    return backup;
}

function restoreSimulation(backup) {
    if (!backup) return;

    // Restore main squares
    board[backup.from.r][backup.from.c] = backup.from.piece ? { ...backup.from.piece } : null;
    board[backup.to.r][backup.to.c] = backup.to.piece ? { ...backup.to.piece } : null;

    // Restore en passsant
    enPassantTarget = backup.enPassant ? { ...backup.enPassant } : null;

    // Restore captured en-passant pawn
    if (backup.capturedEnPassant) {
        board[backup.capturedEnPassant.r][backup.capturedEnPassant.c] = backup.capturedEnPassant.piece ? { ...backup.capturedEnPassant.piece } : null;
    }

    // Restore castling rook if any
    if (backup.castle) {
        const fr = backup.from.r;
        board[fr][backup.castle.rookFrom] = backup.castle.rookPiece ? { ...backup.castle.rookPiece } : null;
        board[fr][backup.castle.rookTo] = null;
    }

    // Restore moved flag for piece on from square (if exists)
    const fromPiece = board[backup.from.r][backup.from.c];
    if (fromPiece && typeof backup.pieceMoved !== 'undefined') {
        fromPiece.moved = backup.pieceMoved;
    }
}

function isCheckmate(color) {

    if (!isCheck(color)) return false;

    for (let fr = 0; fr < SIZE; fr++) {
        for (let fc = 0; fc < SIZE; fc++) {

            let piece = board[fr][fc];
            if (!piece || piece.color !== color) continue;

            for (let tr = 0; tr < SIZE; tr++) {
                for (let tc = 0; tc < SIZE; tc++) {

                    if (!isValidMove(fr, fc, tr, tc, piece)) continue;

                    // simulate using full rules
                    const backup = simulateMove(fr, fc, tr, tc);

                    let stillCheck = isCheck(color);

                    restoreSimulation(backup);

                    if (!stillCheck) return false;
                }
            }
        }
    }

    return true;
}

function findKing(color) {
    for (let r = 0; r < SIZE; r++)
        for (let c = 0; c < SIZE; c++)
            if (board[r][c] &&
                board[r][c].type === "king" &&
                board[r][c].color === color)
                return { r, c };
    return null;
}

function opponent(color) {
    return color === "white" ? "black" : "white";
}

function isStalemate(color) {

    if (isCheck(color)) return false;

    for (let fr = 0; fr < SIZE; fr++)
        for (let fc = 0; fc < SIZE; fc++) {

            let piece = board[fr][fc];
            if (!piece || piece.color !== color) continue;

            for (let tr = 0; tr < SIZE; tr++)
                for (let tc = 0; tc < SIZE; tc++) {

                    if (!isValidMove(fr, fc, tr, tc, piece))
                        continue;

                    const backup = simulateMove(fr, fc, tr, tc);

                    let stillCheck = isCheck(color);

                    restoreSimulation(backup);

                    if (!stillCheck) return false;
                }
        }

    return true;
}

function getBoardKey() {
    return JSON.stringify({
        board,
        currentPlayer: window.currentPlayer
    });
}

function savePosition() {
    let key = getBoardKey();
    positionHistory[key] = (positionHistory[key] || 0) + 1;
}

function promote(type) {

    if (!pendingPromotion) return;

    board[pendingPromotion.r][pendingPromotion.c].type = type;

    let color = pendingPromotion.color;
    pendingPromotion = null;

    savePosition();

    if (isCheckmate(opponent(color))) {
        alert(color + " wins by checkmate!");
        gameOver = true;
    }

    window.currentPlayer = opponent(color);
}

function showPromotionMenu() {
    document.getElementById("promotionMenu").style.display = "block";
}